{# ============================================================
 * fmi2_router.h —— VR 路由表
 * 由 fmu-pack 自动生成，勿手动编辑
 *
 * 模板变量:
 *   model_identifier: FMU 模型标识符
 *   state_type:      用户状态结构体类型名
 *   variables:       变量列表（每项: name, vr, type, causality）
 * ============================================================ #}
#ifndef FMI2_ROUTER_H_
#define FMI2_ROUTER_H_

/* ============================================================
 * fmi2_router.h —— VR 路由表（由 fmu-pack 自动生成，勿手动编辑）
 * 模型:     {{ model_identifier }}
 * 状态类型: {{ state_type }}
 * 变量数:   {{ variables | length }}
 * ============================================================ */

#include "fmi2TypesPlatform.h"
#include "user_model.h"

/* ---- valueReference 枚举 ---- */
typedef enum {
{% for var in variables %}
{% if var.type == "Real" %}
    VR_{{ var.name | upper }} = {{ var.vr }},  /* {{ var.causality | default("local") }} */
{% endif %}
{% endfor %}
    VR_COUNT = {{ variables | length }}
} {{ model_identifier }}_VR;


/* ---- getReal 路由（内联函数） ---- */
static inline void {{ model_identifier }}_route_getReal({{ state_type }}* state,
                                       const fmi2ValueReference vr[],
                                       size_t nvr,
                                       fmi2Real value[]) {
    for (size_t i = 0; i < nvr; i++) {
        switch (vr[i]) {
{% for var in variables %}
{% if var.type == "Real" %}
        case VR_{{ var.name | upper }}: value[i] = state->{{ var.name }}; break;
{% endif %}
{% endfor %}
            default: break;
        }
    }
}

/* ---- setReal 路由（内联函数） ---- */
static inline void {{ model_identifier }}_route_setReal({{ state_type }}* state,
                                       const fmi2ValueReference vr[],
                                       size_t nvr,
                                       const fmi2Real value[]) {
    for (size_t i = 0; i < nvr; i++) {
        switch (vr[i]) {
{% for var in variables %}
{% if var.type == "Real" and var.causality in ("input", "parameter") %}
        case VR_{{ var.name | upper }}: state->{{ var.name }} = value[i]; break;
{% endif %}
{% endfor %}
            default: break;
        }
    }
}

#endif /* FMI2_ROUTER_H_ */
