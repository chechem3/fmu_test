{# ============================================================
 * fmi2_router.h —— VR 路由表
 * 由 fmu-pack 自动生成，勿手动编辑
 *
 * 设计: 路由函数名固定为 model_route_getReal/_setReal
 *       接收 void* state，由用户模型在 user_model.h 中定义具体类型
 *       适配层 fmi2_adapter.c 完全不感知 state type
 * ============================================================ #}
#ifndef FMI2_ROUTER_H_
#define FMI2_ROUTER_H_

/* ============================================================
 * fmi2_router.h —— VR 路由表（由 fmu-pack 自动生成，勿手动编辑）
 * 状态类型: {{ state_type }}
 * 变量数:   {{ variables | length }}
 * ============================================================ */

#include "fmi2TypesPlatform.h"
#include "user_model.h"

/* ---- valueReference 枚举 ---- */
typedef enum {
{% for var in variables %}
{% if var.type == "Real" %}
    VR_{{ var.name | upper }} = {{ var.vr }},  /* {{ var.causality | default("local") }} */
{% endif %}
{% endfor %}
    VR_COUNT = {{ variables | length }}
} ModelVR;


/* ---- getReal 路由（内联函数，固定名 model_route_getReal）---- */
static inline void model_route_getReal(void* state,
                                       const fmi2ValueReference vr[],
                                       size_t nvr,
                                       fmi2Real value[]) {
    {{ state_type }}* s = ({{ state_type }}*)state;
    for (size_t i = 0; i < nvr; i++) {
        switch (vr[i]) {
{% for var in variables %}
{% if var.type == "Real" %}
        case VR_{{ var.name | upper }}: value[i] = s->{{ var.name }}; break;
{% endif %}
{% endfor %}
            default: break;
        }
    }
}

/* ---- setReal 路由（内联函数，固定名 model_route_setReal）---- */
static inline void model_route_setReal(void* state,
                                       const fmi2ValueReference vr[],
                                       size_t nvr,
                                       const fmi2Real value[]) {
    {{ state_type }}* s = ({{ state_type }}*)state;
    for (size_t i = 0; i < nvr; i++) {
        switch (vr[i]) {
{% for var in variables %}
{% if var.type == "Real" and var.causality in ("input", "parameter") %}
        case VR_{{ var.name | upper }}: s->{{ var.name }} = value[i]; break;
{% endif %}
{% endfor %}
            default: break;
        }
    }
}

#endif /* FMI2_ROUTER_H_ */
